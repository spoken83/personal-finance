generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MasterCategory {
  id           Int               @id @default(autoincrement())
  name         String            @unique
  isExcluded   Boolean           @default(false) @map("is_excluded")
  displayOrder Int               @default(0) @map("display_order")
  createdAt    DateTime          @default(now()) @map("created_at")
  spendCategories SpendCategory[]
  transactions    Transaction[]
  budgets         Budget[]

  @@map("master_categories")
}

model SpendCategory {
  id               Int            @id @default(autoincrement())
  name             String         @unique
  masterCategoryId Int            @map("master_category_id")
  masterCategory   MasterCategory @relation(fields: [masterCategoryId], references: [id])
  createdAt        DateTime       @default(now()) @map("created_at")
  transactions     Transaction[]
  rules            CategorizationRule[]
  budgets          Budget[]

  @@map("spend_categories")
}

model BankAccount {
  id          Int           @id @default(autoincrement())
  source      String
  accountName String        @map("account_name")
  accountType String        @default("credit_card") @map("account_type")
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  transactions    Transaction[]
  uploads         StatementUpload[]
  balances        AccountBalance[]

  @@map("bank_accounts")
}

model Transaction {
  id                Int            @id @default(autoincrement())
  bankAccountId     Int            @map("bank_account_id")
  bankAccount       BankAccount    @relation(fields: [bankAccountId], references: [id])
  date              DateTime       @db.Date
  description       String
  amountFcy         Decimal?       @map("amount_fcy") @db.Decimal(12, 2)
  fcyCurrency       String?        @map("fcy_currency") @db.VarChar(3)
  accountingAmt     Decimal        @map("accounting_amt") @db.Decimal(12, 2)
  spendCategoryId   Int            @map("spend_category_id")
  spendCategory     SpendCategory  @relation(fields: [spendCategoryId], references: [id])
  masterCategoryId  Int            @map("master_category_id")
  masterCategory    MasterCategory @relation(fields: [masterCategoryId], references: [id])
  notes             String?
  statementUploadId Int?           @map("statement_upload_id")
  statementUpload   StatementUpload? @relation(fields: [statementUploadId], references: [id])
  isConfirmed       Boolean        @default(false) @map("is_confirmed")
  isAmortized       Boolean        @default(false) @map("is_amortized")
  parentTransactionId Int?         @map("parent_transaction_id")
  parentTransaction Transaction?   @relation("AmortizationSplit", fields: [parentTransactionId], references: [id])
  childTransactions Transaction[]  @relation("AmortizationSplit")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@index([date])
  @@index([bankAccountId, date])
  @@index([masterCategoryId, date])
  @@index([spendCategoryId])
  @@index([parentTransactionId])
  @@map("transactions")
}

model StatementUpload {
  id               Int          @id @default(autoincrement())
  filename         String
  fileType         String       @map("file_type") @db.VarChar(10)
  bankAccountId    Int?         @map("bank_account_id")
  bankAccount      BankAccount? @relation(fields: [bankAccountId], references: [id])
  status           String       @default("processing") @db.VarChar(20)
  rawText          String?      @map("raw_text")
  transactionCount Int?         @map("transaction_count")
  uploadedAt       DateTime     @default(now()) @map("uploaded_at")
  confirmedAt      DateTime?    @map("confirmed_at")
  transactions     Transaction[]

  @@map("statement_uploads")
}

model CategorizationRule {
  id              Int           @id @default(autoincrement())
  pattern         String
  spendCategoryId Int           @map("spend_category_id")
  spendCategory   SpendCategory @relation(fields: [spendCategoryId], references: [id])
  masterCategoryId Int?         @map("master_category_id")
  priority        Int           @default(0)
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("categorization_rules")
}

model AccountBalance {
  id            Int         @id @default(autoincrement())
  bankAccountId Int         @map("bank_account_id")
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  month         DateTime    @db.Date
  actualBalance Decimal     @map("actual_balance") @db.Decimal(14, 2)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([bankAccountId, month])
  @@map("account_balances")
}

model InvestmentAccount {
  id          Int                  @id @default(autoincrement())
  name        String
  provider    String
  accountType String?              @map("account_type")
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at")
  snapshots   InvestmentSnapshot[]

  @@map("investment_accounts")
}

model InvestmentSnapshot {
  id                  Int               @id @default(autoincrement())
  investmentAccountId Int               @map("investment_account_id")
  investmentAccount   InvestmentAccount @relation(fields: [investmentAccountId], references: [id])
  month               DateTime          @db.Date
  balance             Decimal           @db.Decimal(14, 2)
  contributions       Decimal           @default(0) @db.Decimal(14, 2)
  withdrawals         Decimal           @default(0) @db.Decimal(14, 2)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@unique([investmentAccountId, month])
  @@map("investment_snapshots")
}

model Budget {
  id               Int             @id @default(autoincrement())
  masterCategoryId Int?            @map("master_category_id")
  masterCategory   MasterCategory? @relation(fields: [masterCategoryId], references: [id])
  spendCategoryId  Int?            @map("spend_category_id")
  spendCategory    SpendCategory?  @relation(fields: [spendCategoryId], references: [id])
  monthlyAmount    Decimal         @map("monthly_amount") @db.Decimal(12, 2)
  effectiveFrom    DateTime        @map("effective_from") @db.Date
  effectiveTo      DateTime?       @map("effective_to") @db.Date
  createdAt        DateTime        @default(now()) @map("created_at")

  @@map("budgets")
}

model RunwayConfig {
  id                      Int      @id @default(autoincrement())
  totalProceeds           Decimal  @map("total_proceeds") @db.Decimal(14, 2)
  monthlyInvestmentTarget Decimal  @map("monthly_investment_target") @db.Decimal(12, 2)
  expectedReturnRate      Decimal  @map("expected_return_rate") @db.Decimal(5, 4)
  projectionYears         Int      @map("projection_years")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("runway_config")
}
